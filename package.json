{
  "name": "ibl-baker-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test:rust && npm run test:js && npm run test:ibla-viewer && npm run test:ktx2-viewer",
    "test:rust": "cargo test --workspace",
    "test:js": "npm run test -w @ibltools/ibla-loader && npm run test -w @ibltools/ktx2-loader",
    "test:ibla-viewer": "npm run test -w @ibltools/ibla-viewer",
    "test:ktx2-viewer": "npm run test -w @ibltools/ktx2-viewer",
    "check:rs": "cargo check --workspace",
    "check:ts": "tsc -b packages/ibla-loader packages/ktx2-loader packages/ibla-viewer packages/ktx2-viewer --noEmit",
    "dev:ibla-viewer": "npm run dev -w @ibltools/ibla-viewer",
    "dev:ktx2-viewer": "npm run dev -w @ibltools/ktx2-viewer",
    "fixtures:refresh": "node scripts/refresh-fixtures.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  }
}
